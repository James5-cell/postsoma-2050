# PostSoma-2050 Environment Variables Template
# Copy this file to .env.local and fill in the values.
# DO NOT commit .env.local containing real keys to Git.

# 1. Notion API Settings
# Get your integration token from https://www.notion.so/my-integrations
NOTION_API_KEY=your_notion_api_key_here

# Open your Notion database as a full page and copy the ID from the URL:
# https://www.notion.so/username/DATABASE_ID?v=...
NOTION_DATABASE_ID=your_notion_database_id_here

# 2. AI Model Provider Keys (Optional: Required for pre-calculated AI summary generation)
# Get your Gemini API Key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Get your OpenAI API Key from OpenAI Developer Platform: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here
